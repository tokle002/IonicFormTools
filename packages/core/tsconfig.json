{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"jsx": "preserve",
		"declaration": true,
		"declarationDir": "./dist/types",
		"outDir": "./dist",
		"types": ["node"]
	},
	"include": ["src/**/*", "vite.config.ts"],
	"exclude": ["node_modules", "dist"]
}
